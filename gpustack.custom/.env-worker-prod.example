# Copy to gpustack.custom/.env-worker-prod and fill in values.
# gpustack.custom/.env-worker-prod is gitignored — never commit it.
#
# Run with:
#   docker compose -f gpustack.custom/docker-compose-worker.yaml \
#                  --env-file gpustack.custom/.env-worker-prod up -d
#
# This template sticks to GPUStack's official default ports. The compose file's
# ${VAR:-DEFAULT} fallbacks match these, so most port lines below are commented
# out — uncomment only what you want to override.

# ── Build ─────────────────────────────────────────────────────────────────────
# Must match the server's OFFICIAL_TAG.
OFFICIAL_TAG=v2.1.2

# ── Worker identity ───────────────────────────────────────────────────────────
GPUSTACK_CONTAINER_NAME=gpustack-worker

# ── Connect to remote server ──────────────────────────────────────────────────
# The IP/port the server is reachable at from this worker host.
GPUSTACK_SERVER_URL=http://192.168.x.x:80
# Worker registration token. Get it from the server host:
#   cat <data-dir>/token
GPUSTACK_TOKEN=replace-with-worker-token

# IP this worker advertises to the server. Auto-detected if left empty, but
# set it explicitly when the worker has multiple interfaces / is behind NAT.
GPUSTACK_WORKER_IP=
# IP this worker advertises for external access (e.g. inference server URLs).
# Auto-detected if left empty.
GPUSTACK_ADVERTISE_ADDRESS=

# Gateway mode — must match the server.
GPUSTACK_GATEWAY_MODE=auto

# ── Ports ─────────────────────────────────────────────────────────────────────
# All defaults match `gpustack start --help`. Uncomment to override.
#GPUSTACK_WORKER_PORT=10150
#GPUSTACK_WORKER_METRICS_PORT=10151
#GPUSTACK_METRICS_PORT=10161
#GPUSTACK_SERVICE_PORT_RANGE=40000-40063

# HuggingFace mirror — speeds up downloads in China.
HF_ENDPOINT=https://hf-mirror.com

# ── Host paths (mounted into container) ──────────────────────────────────────
GPUSTACK_DATA_DIR_HOST=../gpustack-data
GPUSTACK_CACHE_DIR_HOST=../gpustack-cache

# ── HuggingFace vs ModelScope: cache layout asymmetry ────────────────────────
# GPUStack downloads model files in FLAT layout
# (`owner/repo/{config.json, model.safetensors, ...}`) via HuggingFace's
# `local_dir=` mode — NOT the default HF Hub blob layout
# (`models--owner--repo/{blobs,refs,snapshots}/`). Practical consequence:
#
#   • MODEL_SCOPE_PATH_HOST  CAN reuse a system-wide ModelScope cache.
#                            ModelScope's library default is already flat, so
#                            e.g. /data/shared/modelscope/hub/models works
#                            as-is for both gpustack and other host tools.
#
#   • HF_CACHE_DIR_HOST      CANNOT reuse a system-wide HuggingFace Hub cache
#                            (format mismatch). Point this at a dedicated
#                            gpustack-only directory; gpustack will populate
#                            it in flat layout.
#
# Both are OPTIONAL. Leave unset (default fallback to
# ../gpustack-cache/{huggingface,model_scope}) to behave like upstream.
#HF_CACHE_DIR_HOST=/data/shared/gpustack/huggingface
#MODEL_SCOPE_PATH_HOST=/data/shared/modelscope/hub/models
