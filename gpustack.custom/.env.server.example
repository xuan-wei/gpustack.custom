# Copy to gpustack.custom/.env and fill in values.
# gpustack.custom/.env is gitignored — never commit it.

# ── Build ─────────────────────────────────────────────────────────────────────
# Official GPUStack release this custom build tracks.
OFFICIAL_TAG=v2.1.2

# ── GPUStack server ───────────────────────────────────────────────────────────
GPUSTACK_BOOTSTRAP_PASSWORD=changeme
GPUSTACK_API_PORT=80
GPUSTACK_GATEWAY_MODE=auto

# External PostgreSQL connection string.
GPUSTACK_DATABASE_URL=postgresql://user:password@127.0.0.1:5432/gpustack

# HuggingFace mirror — speeds up downloads in China.
HF_ENDPOINT=https://hf-mirror.com

# ── Host paths (mounted into container) ──────────────────────────────────────
#GPUSTACK_DATA_DIR_HOST=../gpustack-data
#GPUSTACK_CACHE_DIR_HOST=../gpustack-cache

# ModelScope cache directory on the host.
#MODEL_SCOPE_PATH_HOST=../gpustack-cache/modelscope
