# Copy to gpustack.custom/.env-worker-dev and fill in values.
# gpustack.custom/.env-worker-dev is gitignored — never commit it.
#
# Run with:
#   docker compose -f gpustack.custom/docker-compose-worker.yaml \
#                  --env-file gpustack.custom/.env-worker-dev up -d
#
# Every port is offset by +10000 from GPUStack defaults so this dev worker can
# coexist with a prod worker on the same host without conflicts.

# ── Build ─────────────────────────────────────────────────────────────────────
# Must match the server's OFFICIAL_TAG.
OFFICIAL_TAG=v2.1.2

# ── Worker identity ───────────────────────────────────────────────────────────
GPUSTACK_CONTAINER_NAME=gpustack-worker-dev

# ── Connect to remote server ──────────────────────────────────────────────────
# The IP/port the dev server is reachable at from this worker host.
# Dev server's public API port is 28080 by default (per .env-server-dev).
GPUSTACK_SERVER_URL=http://192.168.x.x:28080
# Worker registration token from the dev server. Get it on the server host:
#   cat <data-dir>/token   (data-dir = ../gpustack-data for dev)
GPUSTACK_TOKEN=replace-with-worker-token

# IP this worker binds to (vLLM/SGLang/llama.cpp --host, runner sockets).
# MUST be a real local NIC on this host. Leave empty for auto-detect.
# When behind NAT, set to the PRIVATE LAN address — NOT the public IP, or
# host_network containers will fail with `Cannot assign requested address`.
GPUSTACK_WORKER_IP=
# Address the server uses to reach this worker (metrics scrape, model proxy).
# Leave empty when worker and server share a flat network. Set explicitly to
# the PUBLIC/routable address when crossing NAT.
GPUSTACK_ADVERTISE_ADDRESS=

# Gateway mode — must match the server.
GPUSTACK_GATEWAY_MODE=auto

# ── Ports — offset +10000 from official defaults ──────────────────────────────
# Prod (defaults):  10150, 10151, 10161, 40000-40063
# Dev  (+10000):    20150, 20151, 20161, 50000-50063
GPUSTACK_WORKER_PORT=20150
GPUSTACK_WORKER_METRICS_PORT=20151
GPUSTACK_METRICS_PORT=20161
GPUSTACK_SERVICE_PORT_RANGE=50000-50063

# HuggingFace mirror — speeds up downloads in China.
HF_ENDPOINT=https://hf-mirror.com

# ── Host paths (mounted into container) ──────────────────────────────────────
GPUSTACK_DATA_DIR_HOST=../gpustack-data
GPUSTACK_CACHE_DIR_HOST=../gpustack-cache

# ── HuggingFace vs ModelScope: cache layout asymmetry ────────────────────────
# See .env-worker-prod.example for the full explanation.
#HF_CACHE_DIR_HOST=/data/shared/gpustack/huggingface
#MODEL_SCOPE_PATH_HOST=/data/shared/modelscope/hub/models
