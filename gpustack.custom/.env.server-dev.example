# Copy to gpustack.custom/.env.server-dev and fill in values.
# gpustack.custom/.env.server-dev is gitignored — never commit it.

# ── Build ─────────────────────────────────────────────────────────────────────
OFFICIAL_TAG=v2.1.2

# ── GPUStack server+worker ────────────────────────────────────────────────────
GPUSTACK_BOOTSTRAP_PASSWORD=changeme
GPUSTACK_GATEWAY_MODE=auto

# Ports — offset from production (+10000) to avoid conflicts.
# Production uses: 18080, 10150, 10151, 40000-40063, 40064-40095
GPUSTACK_API_PORT=28080
GPUSTACK_WORKER_PORT=20150
GPUSTACK_METRICS_PORT=20151
GPUSTACK_SERVICE_PORT_RANGE=50000-50063

# HuggingFace mirror — speeds up downloads in China.
HF_ENDPOINT=https://hf-mirror.com

# ── Host paths (mounted into container) ──────────────────────────────────────
#GPUSTACK_DATA_DIR_HOST=../gpustack-data
#GPUSTACK_CACHE_DIR_HOST=../gpustack-cache

# ModelScope cache directory on the host (can be shared with production).
#MODEL_SCOPE_PATH_HOST=../gpustack-cache/modelscope
