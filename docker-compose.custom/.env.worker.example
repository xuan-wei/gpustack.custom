# Copy to docker-compose.custom/.env and fill in values.
# docker-compose.custom/.env is gitignored — never commit it.

# ── Build ─────────────────────────────────────────────────────────────────────
# Official GPUStack release this custom build tracks.
OFFICIAL_TAG=v2.1.2

# GPUStack gateway mode.
GPUSTACK_GATEWAY_MODE=auto

# ── Worker registration ───────────────────────────────────────────────────────
GPUSTACK_TOKEN=replace-with-worker-token
GPUSTACK_SERVER_URL=http://192.168.43.7:18080
GPUSTACK_WORKER_IP=1.1.1.1
GPUSTACK_ADVERTISE_ADDRESS=2.2.2.2

# HuggingFace mirror — speeds up downloads in China.
HF_ENDPOINT=https://hf-mirror.com

# ── Host paths (mounted into container) ──────────────────────────────────────
#GPUSTACK_DATA_DIR_HOST=../gpustack-data
#GPUSTACK_CACHE_DIR_HOST=../gpustack-cache

# ModelScope cache directory on the host.
#MODEL_SCOPE_PATH_HOST=../gpustack-cache/modelscope

# Host path to the model catalog YAML file (baked into the image but overridable).
#MODEL_CATALOG_HOST=../gpustack/gpustack/assets/model-catalog-modelscope.yaml
